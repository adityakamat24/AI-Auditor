{
  "uid": "auditor-calibration",
  "title": "Auditor Calibration",
  "description": "Per-category precision and recall trends, judge call rates - AI Auditor Phase 7",
  "tags": ["ai-auditor", "calibration"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Precision - ASI01 (Goal Hijack)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "green",  "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "auditor_calibration_precision{category=\"ASI01\"}",
          "legendFormat": "ASI01",
          "refId": "A"
        }
      ]
    },
