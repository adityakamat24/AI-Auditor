# AI Auditor configuration. Copy to `.env` and adjust. NEVER commit `.env`.
# Field names map 1:1 to auditor/config.py Settings (case-insensitive).
# IMPORTANT: keep comments on their OWN lines. python-dotenv can fold a trailing
# inline "# comment" into the value (especially for empty values), breaking validation.

# --- Core ---
AUDITOR_ENV=dev
LOG_LEVEL=INFO
DATA_DIR=./data

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Postgres (async asyncpg DSN) ---
POSTGRES_DSN=postgresql+asyncpg://auditor:auditor@localhost:5432/auditor

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO / object storage ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_AUDIT=audit
MINIO_BUCKET_CHECKPOINTS=checkpoints
MINIO_BUCKET_GROUND_TRUTH=ground-truth

# --- OPA (policy engine REST API base) ---
OPA_URL=http://localhost:8181

# --- LLM judge (via LiteLLM proxy) ---
# Leave ANTHROPIC_API_KEY blank in dev -> the judge uses the deterministic offline stub.
LITELLM_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6
CROSSCHECK_MODEL=claude-sonnet-4-6

# --- Embeddings (LOCAL by default; see plan deviation #2) ---
# EMBEDDING_BACKEND: fastembed | voyage | stub
EMBEDDING_BACKEND=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- IPC (auditor <-> harness) ---
# IPC_TRANSPORT: blank = auto (unix on POSIX, loopback TCP on Windows) | unix | tcp
IPC_TRANSPORT=
IPC_UNIX_PATH=/tmp/ai-auditor.sock
IPC_TCP_HOST=127.0.0.1
IPC_TCP_PORT=8787
IPC_MTLS_ENABLED=false
IPC_SERVER_ENABLED=true

# --- Secrets backend: env (only impl in v1) | vault | aws ---
SECRETS_BACKEND=env

# --- Auth (Phase 7) ---
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=3600
